# Python virtualenv — regenerated with `uv sync`, never committed
.venv/
__pycache__/

# Rendered diagram outputs
*.png
# ...except the committed worked-example renders (they show "what good looks like")
!references/examples/*.png

# NOTE: uv.lock IS committed (pins Playwright for reproducible renders).
# NOTE: references/vendor/ IS committed — it's the offline render engine.

# User-supplied icon libraries (licensed vendor art) + their split output.
# Keep only the setup README tracked.
references/libraries/*
!references/libraries/README.md
